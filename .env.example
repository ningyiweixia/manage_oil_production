APP_NAME=采油二厂井下作业管理系统
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

POSTGRES_SERVER=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DB=manage_factory

JWT_SECRET_KEY=please-change-this-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_MINUTES=10080
REDIS_URL=redis://:change-me-strong-redis-password@127.0.0.1:6379/0
REDIS_PASSWORD=change-me-strong-redis-password
ADMIN_INITIAL_PASSWORD=change-me-strong-admin-password
CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

AUTH_WHITELIST=/docs,/docs/oauth2-redirect,/redoc,/openapi.json,/health,/api/v1/auth/login,/api/v1/auth/refresh,/api/v1/auth/logout

# Container deployment
DMZ_HTTP_PORT=80
DMZ_HTTPS_PORT=443
PYTHON_BASE_IMAGE=python:3.12-slim
NODE_BASE_IMAGE=node:22-alpine
NGINX_BASE_IMAGE=nginx:1.27-alpine
POSTGRES_IMAGE=postgres:15
REDIS_IMAGE=redis:7.4-alpine
MINIO_IMAGE=minio/minio:RELEASE.2025-04-22T22-12-26Z
PROMETHEUS_IMAGE=prom/prometheus:v3.3.0
GRAFANA_IMAGE=grafana/grafana:12.0.0
CADVISOR_IMAGE=gcr.io/cadvisor/cadvisor:v0.52.1
NODE_EXPORTER_IMAGE=prom/node-exporter:v1.9.1
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=ChangeMe_MinIO_123456
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ChangeMe_Grafana_123456
GRAFANA_ROOT_URL=https://manage-factory.internal/grafana/
PROMETHEUS_RETENTION=30d
