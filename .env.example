APP_NAME=采油二厂井下作业管理系统
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

POSTGRES_SERVER=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=manage_factory

JWT_SECRET_KEY=please-change-this-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_MINUTES=10080
REDIS_URL=redis://127.0.0.1:6379/0
CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

AUTH_WHITELIST=/docs,/docs/oauth2-redirect,/redoc,/openapi.json,/health,/api/v1/auth/login,/api/v1/auth/refresh,/api/v1/auth/logout
